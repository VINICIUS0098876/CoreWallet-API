{
  "compilerOptions": {
    "target": "ES2022",
    "allowJs": true,
    "module": "CommonJS",
    "rootDir": "./src",
    "outDir": "./dist",
    "types": ["mocha", "jest"],
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*", "src/__tests__/**/*","src/prisma.config.ts"]
}
